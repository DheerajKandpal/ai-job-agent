# =========================
# App
# =========================
# Runtime mode: development | production
APP_ENV=development
# Enable debug responses/log detail (auto: true in dev, false in prod)
DEBUG=true
# FastAPI server port
PORT=8000
# Service name used in logs and metadata
APP_NAME=ai-job-agent-api

# =========================
# Security
# =========================
# Required bearer token for all protected routes
API_KEY=your-api-key-here

# =========================
# Database (PostgreSQL)
# =========================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ai_job_agent
DB_USER=postgres
DB_PASSWORD=your-db-password-here

# =========================
# LLM (Ollama)
# =========================
# Ollama server URL
OLLAMA_BASE_URL=http://127.0.0.1:11434
# Model used for resume tailoring and cover letter generation
MODEL_NAME=qwen2.5-coder
# LLM request timeout in seconds
LLM_TIMEOUT=30

# =========================
# CORS
# =========================
# Comma-separated allowed frontend origins.
# Required in production. In development defaults to localhost Streamlit origins.
CORS_ORIGINS=http://localhost:8501,http://127.0.0.1:8501

# =========================
# Rate Limiting
# =========================
RATE_LIMIT_MAX_REQUESTS=10
RATE_LIMIT_WINDOW_SECONDS=60

# =========================
# Resume
# =========================
# Default resume version key in the resumes table
RESUME_VERSION=base_v2

# =========================
# Logging
# =========================
# Optional override. Defaults to DEBUG in development, INFO in production.
LOG_LEVEL=DEBUG

# =========================
# Auto-Apply Pipeline (optional)
# =========================
# Backend URL used by the auto-apply runner and CLI pipeline
BASE_URL=http://127.0.0.1:8000

# SMTP config — required only if using email delivery in auto_apply
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_USER=you@example.com
# EMAIL_PASS=replace-with-smtp-password
